# =============================================================================
# ETF Weekly Report - 환경 변수 설정 파일
# =============================================================================
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env
# 실제 API 키나 민감한 정보는 .env 파일에 저장하고, .env는 git에 커밋하지 마세요.
# =============================================================================

# -----------------------------------------------------------------------------
# API 서버 설정
# -----------------------------------------------------------------------------

# API 서버가 바인딩될 호스트 주소
# 0.0.0.0: 모든 네트워크 인터페이스에서 접속 허용 (프로덕션 권장)
# 127.0.0.1: 로컬호스트만 허용 (개발 환경)
API_HOST=0.0.0.0

# API 서버 포트 번호
# 기본값: 8000
# 변경 시 프론트엔드의 VITE_API_BASE_URL도 함께 변경 필요
API_PORT=8000

# API Key for authentication
# 민감한 엔드포인트(데이터 수정/삭제) 접근 시 필요
# 개발 환경: 설정하지 않으면 인증 없이 모든 요청 허용
# 프로덕션: 반드시 설정 권장 (32자 이상 무작위 문자열)
# 예시: openssl rand -hex 32
# API_KEY=your-secret-api-key-here

# CORS (Cross-Origin Resource Sharing) 허용 오리진
# 프론트엔드 애플리케이션의 URL을 쉼표로 구분하여 입력
# 개발 환경: http://localhost:5173 (Vite), http://localhost:3000 (React)
# 프로덕션: 실제 배포 도메인으로 변경 필요 (예: https://etf.example.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# 데이터베이스 설정
# -----------------------------------------------------------------------------

# 데이터베이스 연결 URL
# SQLite: sqlite:///./backend/data/etf_data.db (상대 경로)
# PostgreSQL: postgresql://user:password@localhost:5432/dbname (향후 지원 예정)
# 설정하지 않으면 기본값 사용: backend/data/etf_data.db
# DATABASE_URL=sqlite:///./backend/data/etf_data.db

# -----------------------------------------------------------------------------
# 데이터 수집 및 캐싱 설정
# -----------------------------------------------------------------------------

# 스크래핑 주기 (분 단위)
# 백그라운드 스케줄러가 자동으로 데이터를 수집하는 간격
# 기본값: 3분
# 주의: 너무 짧게 설정하면 외부 API에 부하를 줄 수 있음
# 권장값: 3-10분 (개발: 3분, 프로덕션: 5-10분)
SCRAPING_INTERVAL_MINUTES=6

# API 응답 캐시 유효 시간 (분 단위)
# ⚠️ 현재 미구현: 이 설정은 Config 클래스에 정의되어 있지만 실제로 사용되지 않습니다.
# 향후 Redis 또는 메모리 캐시 구현 시 사용될 예정입니다.
# 기본값: 3분
# 주의: CACHE_TTL_MINUTES는 SCRAPING_INTERVAL_MINUTES보다 작거나 같게 설정 권장
#       (스크래핑 주기보다 긴 캐시는 최신 데이터를 못 볼 수 있음)
CACHE_TTL_MINUTES=3

# 뉴스 검색 최대 결과 수
# 네이버 검색 API에서 가져올 최대 뉴스 개수
# 기본값: 5개 (현재 미사용, 향후 구현 예정)
# 범위: 1-100 (네이버 API 제한)
NEWS_MAX_RESULTS=5

# -----------------------------------------------------------------------------
# 외부 API 설정 (선택사항)
# -----------------------------------------------------------------------------

# 네이버 검색 API 클라이언트 ID
# 네이버 개발자 센터(https://developers.naver.com)에서 발급받은 Client ID
# 뉴스 검색 기능 사용 시 필수
# 발급 방법: 네이버 개발자 센터 > 애플리케이션 등록 > Client ID 확인
NAVER_CLIENT_ID=your_client_id

# 네이버 검색 API 클라이언트 Secret
# 네이버 개발자 센터에서 발급받은 Client Secret
# 뉴스 검색 기능 사용 시 필수
# 보안 주의: 이 값은 절대 git에 커밋하지 마세요!
NAVER_CLIENT_SECRET=your_client_secret

# -----------------------------------------------------------------------------
# 고급 설정 (선택사항)
# -----------------------------------------------------------------------------

# 종목 설정 파일 경로
# 기본값: backend/config/stocks.json
# 변경하지 않는 것을 권장
# STOCK_CONFIG_PATH=backend/config/stocks.json
