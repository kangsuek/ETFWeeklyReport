# ============================================
# ETF Weekly Report - 환경 변수 (프로젝트 루트)
# ============================================
# 백엔드·프론트엔드 모두 이 .env 파일만 사용합니다.
# backend/.env, frontend/.env 는 사용하지 않습니다.
#
# 설정: 이 파일을 복사하여 .env 로 저장한 뒤 값을 채우세요.
#   cp .env.example .env

# ============================================
# 백엔드 - 서버 설정
# ============================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# 백엔드 - 데이터베이스
# ============================================
# SQLite (프로젝트 루트 기준 경로)
DATABASE_URL=sqlite:///backend/data/etf_data.db
# PostgreSQL (사용 시 주석 해제)
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# ============================================
# 백엔드 - API 키 (선택, 미설정 시 모든 요청 허용)
# ============================================
# API_KEY=your-secret-api-key-here

# ============================================
# 백엔드 - Naver API (뉴스 수집)
# ============================================
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ============================================
# 백엔드 - 캐시 / 스크래핑
# ============================================
CACHE_TTL_MINUTES=0.5
SCRAPING_INTERVAL_MINUTES=3
# 주기 수집 루프에서 뉴스는 이 간격(분) 이내면 건너뜀 (가격/매매동향은 매 주기 유지)
NEWS_COLLECT_INTERVAL_MINUTES=30
# 시각 기반 cron 작업 활성화. 웹 배포(데몬)=true, 데스크톱 App(비데몬)=false 권장
ENABLE_SCHEDULED_JOBS=true
# 종목상세 조회 중 장중 분봉 재수집 임계값(초). 마지막 체결이 이 값보다 오래되면
# 증분 재수집을 트리거한다. 낮출수록 분봉이 자주 갱신되지만 크롤 빈도가 는다.
INTRADAY_RECOLLECT_THRESHOLD_SECONDS=60
# 종목발굴 데이터 수집 freshness 가드(시간). 최근 장 마감분을 확보했거나
# 장중 이 시간 이내 수집했으면 재수집을 스킵한다(force=true면 무시).
SCANNER_COLLECT_TTL_HOURS=6

# ============================================
# 프론트엔드 (VITE_ 접두사)
# ============================================
# API 베이스 URL (개발: 프록시 사용, 프로덕션: 실제 URL)
VITE_API_BASE_URL=/api
# VITE_API_BASE_URL=https://your-backend-domain.com/api

# API 키 (백엔드와 동일하게 설정 시 관리 기능 사용)
# VITE_API_KEY=your-secret-api-key-here

VITE_APP_TITLE=ETF Weekly Report
VITE_APP_VERSION=1.0.0
